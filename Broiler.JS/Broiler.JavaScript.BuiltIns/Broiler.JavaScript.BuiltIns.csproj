<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <PropertyGroup>
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>Generated</CompilerGeneratedFilesOutputPath>
  </PropertyGroup>
  <Target Name="AddSourceGeneratedFiles" AfterTargets="CoreCompile">
    <ItemGroup>
      <Compile Include="Generated\**" />
    </ItemGroup>
  </Target>
  <Target Name="RemoveSourceGeneratedFiles" BeforeTargets="CoreCompile">
    <ItemGroup>
      <Compile Remove="Generated\**" />
    </ItemGroup>
  </Target>

  <ItemGroup>
    <!-- Bundled IANA time-zone database (generated by scripts/tzdata/generate_tzdata.py)
         so Temporal / Date time-zone behaviour does not depend on the host OS tz data. -->
    <EmbeddedResource Include="Temporal\Tz\tzdata.bin" LogicalName="Broiler.JavaScript.BuiltIns.Temporal.Tz.tzdata.bin" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Broiler.JavaScript.LinqExpressions\Broiler.JavaScript.LinqExpressions.csproj" />
    <ProjectReference Include="..\Broiler.JavaScript.Extensions\Broiler.JavaScript.Extensions.csproj" />
    <ProjectReference Include="..\Broiler.JavaScript.JSClassGenerator\Broiler.JavaScript.JSClassGenerator.csproj" ReferenceOutputAssembly="false" OutputItemType="Analyzer" />
    <ProjectReference Include="..\Broiler.JavaScript.Engine\Broiler.JavaScript.Engine.csproj" />
    <!-- Broiler.Regex: the from-scratch ECMAScript regex engine (issue #923). JSRegExp
         routes patterns that hit a JS/.NET semantic gap the source-to-source translator
         into System.Text.RegularExpressions cannot fix (look-behind with captures/
         back-references, nullable quantifiers, code-point back-references, astral atoms)
         through this engine. It is dependency-free, so it adds no transitive packages. -->
    <ProjectReference Include="..\..\Broiler.Regex\Broiler.Regex\Broiler.Regex.csproj">
      <!-- Expose only via the `BRegex` extern alias: the engine's root namespace
           `Broiler.Regex` would otherwise shadow System.Text.RegularExpressions.Regex
           (used unqualified as `Regex` throughout this assembly). PrivateAssets keeps
           that compile-time reference from flowing to downstream projects (which would
           re-introduce the collision); the runtime assembly is still emitted. -->
      <Aliases>BRegex</Aliases>
      <PrivateAssets>all</PrivateAssets>
    </ProjectReference>
    <ProjectReference Include="..\..\Broiler.Unicode\src\UnicodeEmoji.StringProperties\UnicodeEmoji.StringProperties.csproj" />
    <ProjectReference Include="..\..\Broiler.Unicode\src\UnicodeProperties\UnicodeProperties.csproj" />
    <ProjectReference Include="..\..\Broiler.Unicode\src\UnicodeCldr.LocaleData\UnicodeCldr.LocaleData.csproj" />
    <ProjectReference Include="..\..\Broiler.DateTime\src\Broiler.DateTime\Broiler.DateTime.csproj">
      <!-- Expose only via the `ExtendedDateTime` extern alias so the submodule's
           `Broiler.DateTime` namespace does not shadow System.DateTime. PrivateAssets
           keeps that compile-time reference from flowing to downstream projects (which
           would re-introduce the collision); the runtime assembly is still emitted. -->
      <Aliases>ExtendedDateTime</Aliases>
      <PrivateAssets>all</PrivateAssets>
    </ProjectReference>
  </ItemGroup>

</Project>
